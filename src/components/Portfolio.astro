<!-- 
==============
PORTFOLIO
============== 
-->
<section id="portfolio" class="bg-gray-800 py-20 2xl:py-40 overflow-hidden">
  <div class="container mx-auto px-4">
    <div class="max-w-xl mx-auto mb-12 lg:mb-28 text-center">
      <span class="text-lg text-blue-400 font-semibold">The latest from BurlingtonIO</span>
      <h2 class="mt-8 text-5xl text-white font-bold font-heading">Our Work</h2>
    </div>
    <!-- Tabs -->
    <div
      x-data="{ 
      tabSelected: 1,
      tabId: $id('tabs'),
      tabButtonClicked(tabButton){
          this.tabSelected = tabButton.id.replace(this.tabId + '-', '');
          let list = document.querySelector('#portfolioUL');
          let listChildren = list.getElementsByTagName('a');
          Array.prototype.forEach.call(listChildren, function(node){
            node.classList.remove('text-white');
            node.classList.add('text-gray-300');
          });
          tabButton.classList.add('text-white');
          tabButton.classList.remove('text-gray-300');
      },
      tabContentActive(tabContent){
          return this.tabSelected == tabContent.id.replace(this.tabId + '-content-', '');
      },
      tabImageActive(tabImage){
        return this.tabSelected == tabImage.id.replace(this.tabId + '-image-', '');
    },
    }"
      class="flex flex-wrap -mx-5"
    >
      <div class="w-full lg:w-1/3 px-5 pt-10 lg:pt-20 pb-10">
        <ul id="portfolioUL" class="text-gray-300">
          <li class="pb-5 border-b border-gray-500">
            <a
              :id="$id(tabId)"
              @click="tabButtonClicked($el);"
              class="inline-block py-6 px-12 rounded-lg text-lg text-gray-300 hover:text-burlingtonBlue font-bold cursor-pointer"
              >American Building Supply</a
            >
          </li>
          <li class="py-6 border-b border-gray-500">
            <a
              :id="$id(tabId)"
              @click="tabButtonClicked($el);"
              class="inline-block py-6 px-12 text-lg text-gray-300 hover:text-burlingtonBlue cursor-pointer"
              >BurlingtonIO</a
            >
          </li>
          <li class="py-6 border-b border-gray-500">
            <a
              :id="$id(tabId)"
              @click="tabButtonClicked($el);"
              class="inline-block py-6 px-12 text-lg text-gray-300 hover:text-burlingtonBlue cursor-pointer"
              >Las Vegas Chronicle</a
            >
          </li>
          <li class="py-6 border-b border-gray-500">
            <a
              :id="$id(tabId)"
              @click="tabButtonClicked($el);"
              class="inline-block py-6 px-12 text-lg text-gray-300 hover:text-burlingtonBlue cursor-pointer"
              >The Raider Ramble</a
            >
          </li>
        </ul>
      </div>
      <div class="w-1/2 container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="max-w-xl mx-auto mb-12 lg:mb-28 text-center"></div>
          <div class="flex mb-12 flex-wrap -mx-6">
          <!-- IMAGES -->
          <div               
          :id="$id(tabId + '-image')"
          x-show="tabImageActive($el)"
          class="w-full lg:w-3/5 px-6 mb-12 lg:mb-0">
            <img
            class="h-112 w-full object-cover"
            src="/images/ABS.webp"
            alt="ABS website image"
            />              
          </div>
          <!-- IMAGES -->
          <div               
          :id="$id(tabId + '-image')"
          x-show="tabImageActive($el)"
          class="w-full lg:w-3/5 px-6 mb-12 lg:mb-0">
            <img
            class="h-112 w-full object-cover object-left"
            src="/images/Burlington.webp"
            alt="BurlingtonIO website image"
            />              
          </div>
          <!-- IMAGES -->
          <div               
          :id="$id(tabId + '-image')"
          x-show="tabImageActive($el)"
          class="w-full lg:w-3/5 px-6 mb-12 lg:mb-0">
            <img
            class="h-112 w-full object-cover object-left"
            src="/images/LVC.webp"
            alt="Las Vegas Chronicle website image"
            />              
          </div>
          <!-- IMAGES -->
          <div               
          :id="$id(tabId + '-image')"
          x-show="tabImageActive($el)"
          class="w-full lg:w-3/5 px-6 mb-12 lg:mb-0">
            <img
            class="h-112 w-full object-cover"
            src="/images/Raider Ramble.webp"
            alt="Raider Ramble website image"
          />              
          </div>

            <!-- INFO -->
            <div
              :id="$id(tabId + '-content')"
              x-show="tabContentActive($el)"
              class="w-full lg:w-2/5 px-6"
            >
              <div
                class="relative h-full px-6 lg:px-12 py-10 bg-gray-600 rounded-lg"
              >
                <div
                  class="absolute top-0 left-0 -mt-6 ml-6 lg:-ml-6 lg:mt-6 w-14 h-14 bg-gray-600"
                  style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
                >
                </div>
                <h3 class="mb-1 text-2xl font-bold text-white">
                  <a href="https://abs-abs.com" target="_blank"
                    >American Building Supply</a
                  >
                </h3>
                <p class="mb-12 text-burlingtonBlue">Static Site</p>
                <p class="mb-12 text-lg text-gray-300">
                  Static website with dynamic functionality for building supply
                  company
                </p>
              </div>
            </div>

            <!-- INFO -->
            <div
              :id="$id(tabId + '-content')"
              x-show="tabContentActive($el)"
              class="w-full lg:w-2/5 px-6"
            >
              <div
                class="relative h-full px-6 lg:px-12 py-10 bg-gray-600 rounded-lg"
              >
                <div
                  class="absolute top-0 left-0 -mt-6 ml-6 lg:-ml-6 lg:mt-6 w-14 h-14 bg-gray-600"
                  style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
                >
                </div>
                <h3 class="mb-1 text-2xl font-bold text-white">
                  <a>BurlingtonIO</a>
                </h3>
                <p class="mb-12 text-burlingtonBlue">Static Site</p>
                <p class="mb-12 text-lg text-gray-300">
                  Our own static website optimized for speed and cached for
                  slower connections
                </p>
              </div>
            </div>

            <!-- INFO -->
            <div
              :id="$id(tabId + '-content')"
              x-show="tabContentActive($el)"
              class="w-full lg:w-2/5 px-6"
            >
              <div
                class="relative h-full px-6 lg:px-12 py-10 bg-gray-600 rounded-lg"
              >
                <div
                  class="absolute top-0 left-0 -mt-6 ml-6 lg:-ml-6 lg:mt-6 w-14 h-14 bg-gray-600"
                  style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
                >
                </div>
                <h3 class="mb-1 text-2xl font-bold text-white">
                  <a href="https://lvchronicle.com" target="_blank"
                    >Las Vegas Chronicle</a
                  >
                </h3>
                <p class="mb-12 text-burlingtonBlue">CMS</p>
                <p class="mb-12 text-lg text-gray-300">
                  Sports content website hosted externally; WordPress with
                  custom features
                </p>
              </div>
            </div>

            <!-- INFO -->
            <div
              :id="$id(tabId + '-content')"
              x-show="tabContentActive($el)"
              class="w-full lg:w-2/5 px-6"
            >
              <div
                class="relative h-full px-6 lg:px-12 py-10 bg-gray-600 rounded-lg"
              >
                <div
                  class="absolute top-0 left-0 -mt-6 ml-6 lg:-ml-6 lg:mt-6 w-14 h-14 bg-gray-600"
                  style="clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);"
                >
                </div>
                <h3 class="mb-1 text-2xl font-bold text-white">
                  <a href="https://raiderramble.com" target="_blank"
                    >The Raider Ramble</a
                  >
                </h3>
                <p class="mb-12 text-burlingtonBlue">CMS | Ad Support</p>
                <p class="mb-12 text-lg text-gray-300">
                  Sports content website hosted externally; WordPress with
                  custom features and ad support for monetization
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
