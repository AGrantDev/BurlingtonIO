<section class="py-8 px-4 lg:px-10 bg-body">
    <nav class="relative flex justify-between items-center">
      <a class="text-2xl ml-8 text-white font-bold" href="#">
        <img class="h-14" src="/images/BIO-small-transparent.svg" alt="BurlingtonIO logo" width="auto">
      </a>
      <button id = "navButton" class="p-2 navbar-burger">
        <svg class="w-10 h-3" width="39" height="13" viewBox="0 0 39 13" fill="none" xmlns="http://www.w3.org/2000/svg"><rect width="39" height="2" rx="1" fill="#C4C4C4"></rect><rect x="19" y="11" width="20" height="2" rx="1" fill="#C4C4C4"></rect></svg>
      </button>
    </nav>
    <div id = "nav" class="hidden navbar-menu fixed top-0 left-0 bottom-0 w-5/6 max-w-sm z-50">
      <div id ="navOverlay" class="navbar-backdrop fixed inset-0  opacity-80"></div>
      <nav class="relative flex flex-col py-8 h-full w-full bg-gray-500 overflow-y-auto">
        <div class="flex items-center mb-16 pr-6">
          <a class="pl-16 text-2xl text-gray-800 font-bold" href="#">
            <img class="h-7" src="/images/BIO-small-transparent.svg" alt="BurlingtonIO logo" width="auto">
          </a>
        </div>
        <div>
          <ul>
            <li class="mb-1 px-10"><a class="block pl-8 py-4 text-xl text-white hover:bg-blueGray-50 hover:text-gray-800 rounded-xl" href="#services">Services</a></li>
            <li class="mb-1 px-10"><a class="block pl-8 py-4 text-xl text-white hover:bg-blueGray-50 hover:text-gray-800 rounded-xl" href="#portfolio">Our Work</a></li>
            <li class="mb-1 px-10"><a class="block pl-8 py-4 text-xl text-white hover:bg-blueGray-50 hover:text-gray-800 rounded-xl" href="#contact">Contact</a></li>
          </ul>
        </div>
        <div class="mt-auto px-10">
          <p class="mt-6 mb-4 text-lg text-center text-white">
            <span>2023 © BurlingtonIO</span>
          </p>
        </div>
      </nav>
    </div>
</section>

<script>
  let nav = document.querySelector("#nav");
  let navButton = document.querySelector("#navButton");
  let navOverlay = document.querySelector("#navOverlay");

  navButton.addEventListener("click", function(){
    nav.classList.remove("hidden");
  })

  navOverlay.addEventListener("click", function(){
    nav.classList.add("hidden");
  })
</script>